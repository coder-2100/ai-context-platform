{
  "name": "ai-context-platform",
  "private": true,
  "description": "企业级 AI Coding 知识管理与运行时系统",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "validate": "tsx scripts/validate-manifest.ts && tsx scripts/sync-versions.ts",
    "sync-versions": "tsx scripts/sync-versions.ts",
    "generate:schema": "tsx scripts/generate-json-schema.ts",
    "docs:dev": "pnpm --filter @coder-2100/docs dev",
    "docs:build": "pnpm --filter @coder-2100/docs build",
    "changeset": "changeset",
    "bump": "pnpm changeset version && tsx scripts/sync-manifest-versions.ts",
    "release": "pnpm build && pnpm test && pnpm changeset publish",
    "generate": "plop"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@changesets/cli": "catalog:",
    "plop": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "yaml": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
